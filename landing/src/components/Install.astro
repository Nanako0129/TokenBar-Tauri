---
const repo = 'https://github.com/Nanako0129/TokenBar'
const brew = 'brew install --cask nanako0129/tokenbar/tokenbar'
---

<section class="section install" id="install">
  <div class="container install-grid">
    <div class="install-copy">
      <p class="eyebrow">Two minutes, Apple Silicon</p>
      <h2>Install, click the cat, done.</h2>
      <p>
        TokenBar ships as a signed DMG for <strong>macOS 11+ on Apple Silicon</strong>.
        The fully-qualified cask auto-taps — no separate <code>brew tap</code> step.
      </p>
      <ul class="notes">
        <li><span class="dot"></span>The in-app updater checks GitHub Releases on launch and every 30 min.</li>
        <li><span class="dot"></span>Signed artifacts are verified against the embedded public key before install.</li>
        <li><span class="dot"></span>Prefer a one-off? Grab the DMG from Releases.</li>
      </ul>
    </div>

    <div class="install-card">
      <div class="term">
        <div class="term-bar"><i></i><i></i><i></i></div>
        <pre class="term-body"><code><span class="c">$</span> {brew}</code></pre>
        <button class="term-copy mono" id="brew2" type="button">Copy command</button>
      </div>
      <a class="btn btn-ghost full" href={`${repo}/releases/latest`}>Download the DMG ↗</a>
      <p class="src">
        Building from source? <a href={`${repo}#build-from-source`}>Rust + Node ≥ 22</a>.
      </p>
    </div>
  </div>
</section>

<script is:inline>
  const b2 = document.getElementById('brew2')
  if (b2) {
    const cmd = 'brew install --cask nanako0129/tokenbar/tokenbar'
    b2.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(cmd)
        const t = b2.textContent
        b2.textContent = 'Copied ✓'
        b2.classList.add('ok')
        setTimeout(() => { b2.textContent = t; b2.classList.remove('ok') }, 1600)
      } catch {}
    })
  }
</script>

<style>
  .install-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(32px, 6vw, 72px); align-items: center; }
  .install-copy h2 { font-size: clamp(28px, 4.4vw, 46px); margin: 14px 0 16px; }
  .install-copy > p { color: var(--muted); max-width: 46ch; }
  .install-copy strong { color: var(--ink-dim); }
  .install-copy code { font-family: var(--font-mono); font-size: .9em; color: var(--accent-bright); }
  .notes { list-style: none; margin-top: 22px; display: grid; gap: 12px; }
  .notes li { color: var(--muted); font-size: 14.5px; display: flex; gap: 11px; align-items: baseline; }
  .notes .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent); flex: 0 0 auto; transform: translateY(-1px); }

  .install-card {
    background: linear-gradient(180deg, var(--panel-2), var(--panel));
    border: 1px solid var(--line-strong); border-radius: var(--radius);
    padding: 22px; box-shadow: var(--shadow);
  }
  .term { border: 1px solid var(--line); border-radius: var(--radius-sm); overflow: hidden; background: var(--bg); }
  .term-bar { display: flex; gap: 7px; padding: 11px 14px; border-bottom: 1px solid var(--line); }
  .term-bar i { width: 11px; height: 11px; border-radius: 50%; background: var(--line-strong); }
  .term-bar i:nth-child(1){ background:#ff5f57 } .term-bar i:nth-child(2){ background:#febc2e } .term-bar i:nth-child(3){ background:#28c840 }
  .term-body { padding: 18px 16px; }
  .term-body code {
    font-family: var(--font-mono); font-size: clamp(11px, 3.2vw, 13.5px); color: var(--ink);
    /* wrap (and break the long tap/cask token) so it never overflows on phones */
    white-space: pre-wrap; overflow-wrap: anywhere; word-break: break-word;
  }
  .term-body .c { color: var(--accent); }
  /* frosted-glass pill like the hero command, tinted violet for the primary action */
  .term-copy {
    width: 100%; margin-top: 14px; padding: 13px; cursor: pointer;
    background: color-mix(in oklab, var(--accent) 16%, color-mix(in oklab, var(--panel) 70%, transparent));
    color: var(--accent-bright);
    border: 1px solid color-mix(in oklab, var(--accent) 48%, var(--line-strong));
    border-radius: 999px; font-size: 14px; font-weight: 600;
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    transition: transform .18s, border-color .18s, background .18s, color .18s;
  }
  .term-copy:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    background: color-mix(in oklab, var(--accent) 26%, color-mix(in oklab, var(--panel) 60%, transparent));
    color: var(--ink);
  }
  .term-copy.ok { color: var(--p-google); border-color: color-mix(in oklab, var(--p-google) 55%, var(--line-strong)); }
  .btn.full { width: 100%; justify-content: center; margin-top: 12px; }
  .src { margin-top: 16px; text-align: center; font-size: 13px; color: var(--faint); }
  .src a { color: var(--ink-dim); border-bottom: 1px solid var(--line-strong); }

  @media (max-width: 820px) { .install-grid { grid-template-columns: 1fr; } }
</style>
