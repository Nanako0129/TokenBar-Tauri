{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TokenBar",
  "version": "0.4.4",
  "identifier": "com.nyanako.tokenbar",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:4061",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TokenBar",
        "width": 640,
        "height": 620,
        "minWidth": 640,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "visible": false,
        "visibleOnAllWorkspaces": true,
        "center": true,
        "shadow": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState",
          "radius": 14
        }
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["app"],
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-",
      "exceptionDomain": "localhost",
      "dmg": {
        "background": null,
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    },
    "category": "DeveloperTool",
    "shortDescription": "Local AI token usage dashboard",
    "longDescription": "TokenBar is a menubar app that reads local AI coding session logs directly and visualizes token usage as an interactive 3D contribution graph, a live tokens/min trace, and a per-model breakdown. Live updates, per-client filters, and customizable menubar title."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Nanako0129/TokenBar/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI5N0IxQzhFOTU0OUMyN0MKUldSOHdrbVZqaHg3S1p1NmQ0Ti9DdGZJeDhETVpXb3B2R1RObnRhTWJyVmRiRVpHKzJXek54VDMK"
    }
  }
}
